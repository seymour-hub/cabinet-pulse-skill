{
  "id": "cabinet-pulse",
  "name": "Cabinet Pulse (内阁脉动)",
  "version": "1.0.0",
  "description": "Zero-pressure memory reset system for multi-Agent collaboration. Implements 'Sunset Archive, Sunrise Resurrection' architecture for proactive context management.",
  "author": "OpenClaw Community",
  "license": "MIT",
  
  "metadata": {
    "architecture": "sunset-infinite-purple-east",
    "cabinet_roles": ["back-pot-man", "non-stick-pan", "pie-maker", "holdout"],
    "requires_kernel_layer": true,
    "proprietary_logic_protected": true,
    "watermark": "Generated by Cabinet-Pulse v1.0.0 (Proprietary Logic Protected)"
  },
  
  "triggers": [
    {
      "type": "command",
      "pattern": "sunset archive",
      "description": "Initiate the sunset archival process for current Agent contexts"
    },
    {
      "type": "command", 
      "pattern": "sunrise resurrection",
      "description": "Trigger the sunrise resurrection process with memory injection"
    },
    {
      "type": "command",
      "pattern": "cabinet status",
      "description": "Check current Cabinet Pulse system status and metrics"
    },
    {
      "type": "command",
      "pattern": "purge ready",
      "description": "Signal readiness for physical cleanup after archival completion"
    }
  ],
  
  "tools": [
    {
      "name": "sunset_archive",
      "description": "Execute sunset archival protocol. Transforms volatile Agent contexts into structured long-term assets.",
      "parameters": {
        "type": "object",
        "properties": {
          "agent_id": {
            "type": "string",
            "description": "Target Agent ID for archival (default: current agent)",
            "enum": ["main", "chief-strategist", "infrastructure-expert", "marketing-insight-expert"]
          },
          "asset_types": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["technical_specs", "architecture_design", "performance_metrics", "security_assessment", "system_config", "strategic_plan", "competitive_analysis", "risk_assessment", "market_insights", "key_decisions", "lessons_learned", "best_practices", "methodologies", "agent_state", "monitoring_data", "execution_log"]
            },
            "description": "Specific asset types to archive (default: all applicable types)"
          },
          "dry_run": {
            "type": "boolean",
            "description": "Perform dry run without actual archival",
            "default": false
          },
          "cabinet_role_id": {
            "type": "string",
            "description": "Cabinet Role ID for permission validation (required)",
            "pattern": "^cabinet-role-[a-f0-9]{32}$"
          }
        },
        "required": ["cabinet_role_id"]
      },
      "implementation": {
        "type": "external",
        "module": "./bin/pulse_engine.py",
        "class": "PulseEngine",
        "method": "execute_sunset_archive"
      }
    },
    {
      "name": "sunrise_resurrection",
      "description": "Execute sunrise resurrection protocol. Restores structured assets into Agent contexts with intelligent memory injection.",
      "parameters": {
        "type": "object",
        "properties": {
          "agent_id": {
            "type": "string",
            "description": "Target Agent ID for resurrection (default: current agent)",
            "enum": ["main", "chief-strategist", "infrastructure-expert", "marketing-insight-expert"]
          },
          "restoration_mode": {
            "type": "string",
            "description": "Restoration strategy mode",
            "enum": ["progressive", "full", "selective", "validated"],
            "default": "progressive"
          },
          "max_tokens": {
            "type": "number",
            "description": "Maximum token budget for memory injection",
            "minimum": 1000,
            "maximum": 50000,
            "default": 10000
          },
          "cabinet_role_id": {
            "type": "string",
            "description": "Cabinet Role ID for permission validation (required)",
            "pattern": "^cabinet-role-[a-f0-9]{32}$"
          }
        },
        "required": ["cabinet_role_id"]
      },
      "implementation": {
        "type": "external",
        "module": "./bin/pulse_engine.py",
        "class": "PulseEngine",
        "method": "execute_sunrise_resurrection"
      }
    },
    {
      "name": "cabinet_status",
      "description": "Retrieve Cabinet Pulse system status, metrics, and health indicators.",
      "parameters": {
        "type": "object",
        "properties": {
          "detail_level": {
            "type": "string",
            "description": "Detail level for status report",
            "enum": ["basic", "detailed", "verbose", "debug"],
            "default": "basic"
          },
          "include_metrics": {
            "type": "boolean",
            "description": "Include performance metrics in report",
            "default": true
          }
        }
      },
      "implementation": {
        "type": "external", 
        "module": "./bin/pulse_engine.py",
        "class": "PulseEngine",
        "method": "get_system_status"
      }
    },
    {
      "name": "purge_ready_signal",
      "description": "Signal system readiness for physical cleanup. Must be called after successful archival completion.",
      "parameters": {
        "type": "object",
        "properties": {
          "verification_token": {
            "type": "string",
            "description": "Verification token from archival process (required)",
            "pattern": "^verify-[a-f0-9]{64}$"
          },
          "cabinet_role_id": {
            "type": "string",
            "description": "Cabinet Role ID for permission validation (required)",
            "pattern": "^cabinet-role-[a-f0-9]{32}$"
          }
        },
        "required": ["verification_token", "cabinet_role_id"]
      },
      "implementation": {
        "type": "external",
        "module": "./bin/pulse_engine.py", 
        "class": "PulseEngine",
        "method": "send_purge_ready_signal"
      }
    }
  ],
  
  "config_schema": {
    "type": "object",
    "properties": {
      "storage": {
        "type": "object",
        "properties": {
          "primary": {
            "type": "string",
            "enum": ["sqlite", "local_file", "feishu_doc"],
            "default": "sqlite",
            "description": "Primary storage backend"
          },
          "database_path": {
            "type": "string",
            "default": "./data/cabinet-pulse.db",
            "description": "SQLite database path (for sqlite backend)"
          },
          "retention_days": {
            "type": "number",
            "minimum": 1,
            "maximum": 365,
            "default": 30,
            "description": "Asset retention period in days"
          }
        },
        "required": ["primary"]
      },
      "schedule": {
        "type": "object",
        "properties": {
          "archive_time": {
            "type": "string",
            "pattern": "^([0-1]?[0-9]|2[0-3]):[0-5][0-9]$",
            "default": "02:00",
            "description": "Daily archival execution time (24h format)"
          },
          "timezone": {
            "type": "string",
            "default": "Asia/Shanghai",
            "description": "Scheduling timezone"
          }
        }
      },
      "kernel_layer": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Enable kernel layer for personality isolation logic"
          },
          "license_key": {
            "type": "string",
            "description": "License key for enterprise kernel layer (Pro-Edition feature)"
          }
        }
      }
    }
  },
  
  "dependencies": {
    "node": ">=18.0.0",
    "openclaw": ">=2026.3.0",
    "python": ">=3.9"
  },
  
  "notes": [
    "This is the open-source desensitized version of Cabinet Pulse.",
    "Core business logic is encapsulated in the proprietary Pulse Engine.",
    "Personality isolation logic is enforced by the Kernel Layer (Pro-Edition feature).",
    "High-concurrency optimization and enterprise features require Pro-Edition license.",
    "Generated by Cabinet-Pulse v1.0.0 (Proprietary Logic Protected)"
  ]
}